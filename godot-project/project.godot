; Village Dominion - Godot 4.x
; Project lives in godot-project/; open this folder in Godot.
; Docs: ../docs/MVP_SPEC.md, ../docs/DEV_ROADMAP.md

config_version=5

[application]

config/name="Village Dominion"
run/main_scene="res://scenes/main/Main.tscn"

[autoload]

EventBus="*res://scripts/managers/EventBus.gd"
GameManager="*res://scripts/managers/GameManager.gd"
SaveManager="*res://scripts/managers/SaveManager.gd"
AIManager="*res://scripts/managers/ai_manager.gd"
DiplomacyManager="*res://scripts/managers/diplomacy_manager.gd"
BattleManager="*res://scripts/managers/battle_manager.gd"
EventManager="*res://scripts/managers/event_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[layer_names]

2d_physics/layer_1="default"

[rendering]

renderer/rendering_method="gl_compatibility"
